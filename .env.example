APP_ENV=development
APP_ORIGIN=http://localhost:8000
API_HOST=0.0.0.0
API_PORT=8000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=compass
POSTGRES_ADMIN_USER=postgres

REDIS_URL=redis://redis:6379/0

VAULT_ADDR=http://vault:8200
VAULT_TOKEN=dev-only-root-token
VAULT_MOUNT=secret
VAULT_SECRET_PATH=compass

# Required locally. Do not commit a real key.
OPENAI_API_KEY=

# Dev defaults only. Rotate before production.
POSTGRES_PASSWORD=postgres
COMPASS_APP_PASSWORD=compass_app_password
COMPASS_WRITER_PASSWORD=compass_writer_password
JWT_SIGNING_KEY=dev-jwt-signing-key-change-me

UPLOAD_ROOT=/app/.runtime/uploads

# Document object storage (MinIO / S3). STORAGE_BACKEND=local falls back to UPLOAD_ROOT.
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=compass-documents
MINIO_ROOT_USER=compass-minio
MINIO_ROOT_PASSWORD=compass-minio-secret

# OCR: a page is OCR'd only when its text layer is below OCR_MIN_CHARS_PER_PAGE (likely a scan);
# at most OCR_MAX_PAGES pages per document are OCR'd so large scanned docs can't hang ingestion.
OCR_MIN_CHARS_PER_PAGE=20
OCR_MAX_PAGES=100

CACHE_TTL_SEARCH_SECONDS=300
CACHE_TTL_DASH_SECONDS=180
CACHE_TTL_EMBED_SECONDS=86400
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

DEMO_PASSWORD_SUPERUSER=
DEMO_PASSWORD_HR=
DEMO_PASSWORD_MGR=
DEMO_PASSWORD_EMP=
